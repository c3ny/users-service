# ─── SERVER ──────────────────────────────────────────────────────────────────
PORT=3002
NODE_ENV=development

# ─── POSTGRES ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DATABASE=users

# URL completa usada pelo TypeORM (deve refletir as vars acima)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/users

# ─── AUTH ─────────────────────────────────────────────────────────────────────
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Deve ser IGUAL ao JWT_SECRET de todos os outros serviços
JWT_SECRET=

# ─── INTEGRAÇÃO INTERNA ───────────────────────────────────────────────────────
# Segredo compartilhado com blood-stock-service para o webhook /api/stock/init
# DEV: internal-dev-secret | PROD: gerar com openssl rand -hex 32
INTERNAL_SECRET=

# URL do blood-stock-service (Docker: http://bloodstock-service:3004 | Local: http://localhost:3004)
BLOODSTOCK_SERVICE_URL=http://localhost:3004

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ─── OBSERVABILIDADE ─────────────────────────────────────────────────────────
# Source token do BetterStack (Logs > Sources > users-service > Source token)
BETTERSTACK_SOURCE_TOKEN=
LOG_LEVEL=info
